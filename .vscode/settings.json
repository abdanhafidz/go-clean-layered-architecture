{
    // Enables the Go language server (gopls)
    "go.useLanguageServer": true,
    
    // Explicitly tells the language server to work in module mode
    // (This is often the default, but good to be explicit)
    "go.module.enabled": true,

    // When a file is saved, run 'goimports' to automatically format and organize imports
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit"
    },

    // Optional: Setting environment variables specifically for VS Code if needed.
    // For example, if you need a specific path for GOPATH or GOCACHE
    "go.toolsEnvVars": {
        "GO111MODULE": "on" 
    }
}
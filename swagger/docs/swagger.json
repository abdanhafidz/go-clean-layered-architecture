        "/api/v1/files": {
            "post": {
                "description": "Upload one or more files to the server",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Upload"
                ],
                "summary": "Upload Files",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Upload Context (e.g., image, submission, material)",
                        "name": "context",
                        "in": "formData"
                    },
                    {
                        "type": "file",
                        "description": "Files to upload (multiple allowed)",
                        "name": "files",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
